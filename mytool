# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  COLOR PALETTE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RESET="\e[0m"
BOLD="\e[1m"
DIM="\e[2m"

BLACK="\e[30m"
RED="\e[91m"
GREEN="\e[92m"
YELLOW="\e[93m"
BLUE="\e[94m"
MAGENTA="\e[95m"
CYAN="\e[96m"
WHITE="\e[97m"

BG_BLACK="\e[40m"
BG_BLUE="\e[44m"
BG_CYAN="\e[46m"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  HELPER FUNCTIONS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

draw_line() {
    echo -e "${DIM}${BLUE}    ─────────────────────────────────────────────────────────${RESET}"
}

draw_double_line() {
    echo -e "${BOLD}${CYAN}    ═════════════════════════════════════════════════════════${RESET}"
}

draw_thin_line() {
    echo -e "${DIM}${WHITE}    ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${RESET}"
}

print_gap() {
    echo ""
}

section_header() {
    local TITLE="$1"
    local COLOR="${2:-$CYAN}"
    print_gap
    echo -e "    ${COLOR}${BOLD}┌─ ${TITLE} ${RESET}"
    draw_thin_line
}

menu_item() {
    local NUM="$1"
    local ICON="$2"
    local TEXT="$3"
    local COLOR="${4:-$CYAN}"
    printf "    ${COLOR}${BOLD}  %-2s${RESET}  ${WHITE}%s  ${COLOR}%s${RESET}\n" "$NUM" "$ICON" "$TEXT"
}

success_msg() {
    print_gap
    echo -e "    ${GREEN}${BOLD}  ✔  $1${RESET}"
    print_gap
}

error_msg() {
    print_gap
    echo -e "    ${RED}${BOLD}  ✘  $1${RESET}"
    print_gap
}

info_msg() {
    echo -e "    ${YELLOW}  ➜  $1${RESET}"
}

warn_msg() {
    print_gap
    echo -e "    ${YELLOW}${BOLD}  ⚠  $1${RESET}"
    print_gap
}

step_msg() {
    echo -e "    ${BLUE}  ◈  $1${RESET}"
}

prompt_input() {
    print_gap
    echo -ne "    ${CYAN}${BOLD}  ❯  ${WHITE}$1 : ${RESET}"
    read -r "$2"
}

press_enter() {
    print_gap
    draw_line
    echo -ne "    ${DIM}${WHITE}  Press ${BOLD}[ENTER]${RESET}${DIM}${WHITE} to return to menu...${RESET}"
    read
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MAIN MENU FUNCTION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

show_menu() {
    clear

    print_gap
    print_gap
    echo -e "${BOLD}${CYAN}    ╔═════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${BOLD}${CYAN}    ║${RESET}${BOLD}${YELLOW}           ✦  SERVER MANAGEMENT MASTER TOOL  ✦           ${RESET}${BOLD}${CYAN}║${RESET}"
    echo -e "${BOLD}${CYAN}    ║${RESET}${DIM}${WHITE}                 V 3.5   ·   MADE BY PRODIP               ${RESET}${BOLD}${CYAN}║${RESET}"
    echo -e "${BOLD}${CYAN}    ╚═════════════════════════════════════════════════════════╝${RESET}"
    print_gap

    # ── SETUP GROUP ──────────────────────────────────────────────
    section_header "SETUP & CONFIGURATION" "$MAGENTA"
    print_gap
    menu_item " 1" "🛠 " " Initial Setup          " "$GREEN"
    echo -e "    ${DIM}${WHITE}        Install Apache · PHP · MySQL${RESET}"
    print_gap
    menu_item " 2" "🌐" " Setup Domain            " "$GREEN"
    echo -e "    ${DIM}${WHITE}        Link a domain to a project folder${RESET}"
    print_gap
    menu_item "11" "🔒" " Auto SSL (HTTPS)        " "$GREEN"
    echo -e "    ${DIM}${WHITE}        Install Certbot · Secure with HTTPS${RESET}"
    print_gap

    draw_line

    # ── PROJECT GROUP ─────────────────────────────────────────────
    section_header "PROJECT MANAGEMENT" "$CYAN"
    print_gap
    menu_item " 4" "📂" " Show All Projects       " "$CYAN"
    echo -e "    ${DIM}${WHITE}        List all running websites${RESET}"
    print_gap
    menu_item " 5" "🚀" " Install New Project     " "$CYAN"
    echo -e "    ${DIM}${WHITE}        Download & deploy from Google Drive${RESET}"
    print_gap
    menu_item " 7" "🗑 " " Delete a Project        " "$RED"
    echo -e "    ${DIM}${WHITE}        Permanently remove a website${RESET}"
    print_gap
    menu_item "13" "🔍" " Explore & Edit Files    " "$CYAN"
    echo -e "    ${DIM}${WHITE}        Browse PHP files · Open in Nano editor${RESET}"
    print_gap
    menu_item "12" "🔑" " Change Admin Password   " "$MAGENTA"
    echo -e "    ${DIM}${WHITE}        Update & hash web admin passwords${RESET}"
    print_gap

    draw_line

    # ── BACKUP GROUP ──────────────────────────────────────────────
    section_header "BACKUP & STORAGE" "$YELLOW"
    print_gap
    menu_item " 6" "💾" " Backup Project          " "$YELLOW"
    echo -e "    ${DIM}${WHITE}        Zip & upload project to Google Drive${RESET}"
    print_gap
    menu_item " 8" "⚙ " " Install & Setup Rclone  " "$YELLOW"
    echo -e "    ${DIM}${WHITE}        Configure rclone for GDrive access${RESET}"
    print_gap
    menu_item "10" "⏰" " Set Auto Nightly Backup " "$YELLOW"
    echo -e "    ${DIM}${WHITE}        Schedule daily backup at 11:00 PM${RESET}"
    print_gap

    draw_line

    # ── MONITOR GROUP ─────────────────────────────────────────────
    section_header "MONITORING & SECURITY" "$BLUE"
    print_gap
    menu_item " 3" "📊" " Server Health Check     " "$BLUE"
    echo -e "    ${DIM}${WHITE}        Live status of Apache · MySQL · UFW${RESET}"
    print_gap
    menu_item " 9" "🛡 " " Add Security            " "$BLUE"
    echo -e "    ${DIM}${WHITE}        Auto update · Fail2Ban · Firewall${RESET}"
    print_gap

    draw_double_line

    # ── EXIT ──────────────────────────────────────────────────────
    menu_item " 0" "❌" " Exit                    " "$RED"
    print_gap
    draw_double_line

    print_gap
    echo -ne "    ${BOLD}${CYAN}  ❯  ${WHITE}Select an option ${DIM}[0-13]${RESET}${BOLD}${WHITE} : ${RESET}"
    read -r choice
}

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  MAIN LOOP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

while true; do
    show_menu

    case $choice in

        # ══════════════════════════════════════════════════════════
        1)
            clear
            print_gap
            echo -e "${BOLD}${GREEN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${GREEN}    ║          🛠   INITIAL SERVER SETUP                   ║${RESET}"
            echo -e "${BOLD}${GREEN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            step_msg "Updating system packages..."
            sudo apt update -y && sudo apt upgrade -y

            print_gap
            step_msg "Installing Apache, MySQL, PHP and essential tools..."
            sudo apt install apache2 mysql-server php libapache2-mod-php php-mysql zip unzip curl wget -y

            print_gap
            step_msg "Fixing MySQL permissions for admin user..."
            sudo mysql -e "CREATE USER IF NOT EXISTS 'admin'@'localhost' IDENTIFIED WITH mysql_native_password BY '12345'; GRANT ALL PRIVILEGES ON *.* TO 'admin'@'localhost' WITH GRANT OPTION; FLUSH PRIVILEGES;"

            step_msg "Enabling Apache rewrite module..."
            sudo a2enmod rewrite
            sudo systemctl restart apache2

            success_msg "Setup Complete! Your server is ready for projects."
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        2)
            clear
            print_gap
            echo -e "${BOLD}${GREEN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${GREEN}    ║          🌐  SETUP DOMAIN                            ║${RESET}"
            echo -e "${BOLD}${GREEN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "AVAILABLE PROJECTS" "$CYAN"
            print_gap
            ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "    \033[96m  ▸  \033[0m\033[97m" $(NF-1) "\033[0m"}' || error_msg "No projects found!"
            print_gap

            prompt_input "Enter project folder name (e.g. rainbow)" PROJ_DIR

            if [ -d "/var/www/html/$PROJ_DIR" ]; then
                prompt_input "Enter your Domain Name (e.g. example.com)" DOMAIN_NAME
                CONF_FILE="/etc/apache2/sites-available/${DOMAIN_NAME}.conf"

                step_msg "Creating VirtualHost config for ${DOMAIN_NAME}..."
                sudo bash -c "cat > $CONF_FILE" <<EOF
<VirtualHost *:80>
    ServerName $DOMAIN_NAME
    ServerAlias www.$DOMAIN_NAME
    DocumentRoot /var/www/html/$PROJ_DIR

    <Directory /var/www/html/$PROJ_DIR>
        AllowOverride All
        Require all granted
    </Directory>
</VirtualHost>
EOF
                sudo a2ensite ${DOMAIN_NAME}.conf
                sudo systemctl restart apache2
                success_msg "Domain ${DOMAIN_NAME} linked to folder '${PROJ_DIR}' successfully!"
                warn_msg "Make sure your DNS A Record is pointing to this VPS IP."
            else
                error_msg "Folder '$PROJ_DIR' not found! Create/install the project first."
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        3)
            clear
            print_gap
            echo -e "${BOLD}${BLUE}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${BLUE}    ║          📊  SERVER HEALTH CHECK                     ║${RESET}"
            echo -e "${BOLD}${BLUE}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "SERVICE STATUS" "$BLUE"
            print_gap

            if systemctl is-active --quiet apache2; then
                echo -e "    ${BOLD}${WHITE}    🌐  Web Server (Apache)${RESET}    ${BOLD}${GREEN}● RUNNING${RESET}"
            else
                echo -e "    ${BOLD}${WHITE}    🌐  Web Server (Apache)${RESET}    ${BOLD}${RED}● STOPPED${RESET}"
            fi

            print_gap

            if systemctl is-active --quiet mysql; then
                echo -e "    ${BOLD}${WHITE}    🗄  Database (MySQL)  ${RESET}    ${BOLD}${GREEN}● RUNNING${RESET}"
            else
                echo -e "    ${BOLD}${WHITE}    🗄  Database (MySQL)  ${RESET}    ${BOLD}${RED}● STOPPED${RESET}"
            fi

            print_gap

            UFW_STATUS=$(sudo ufw status | grep -w "Status")
            if [[ "$UFW_STATUS" == *"active"* ]]; then
                echo -e "    ${BOLD}${WHITE}    🛡  Firewall (UFW)    ${RESET}    ${BOLD}${GREEN}● ACTIVE${RESET}"
            else
                echo -e "    ${BOLD}${WHITE}    🛡  Firewall (UFW)    ${RESET}    ${BOLD}${RED}● INACTIVE${RESET}"
            fi

            print_gap
            draw_line
            section_header "SYSTEM UPTIME" "$YELLOW"
            print_gap
            echo -e "    ${YELLOW}  ⏱  $(uptime -p)${RESET}"
            print_gap

            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        4)
            clear
            print_gap
            echo -e "${BOLD}${CYAN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${CYAN}    ║          📂  ALL PROJECTS                            ║${RESET}"
            echo -e "${BOLD}${CYAN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "PROJECTS IN /var/www/html/" "$CYAN"
            print_gap
            ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "    \033[96m  ▸  \033[0m\033[97m" $(NF-1) "\033[0m"}' || error_msg "No projects found."
            print_gap

            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        5)
            clear
            print_gap
            echo -e "${BOLD}${GREEN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${GREEN}    ║          🚀  INSTALL NEW PROJECT                     ║${RESET}"
            echo -e "${BOLD}${GREEN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            prompt_input "Enter Google Drive Share Link" LINK
            FILE_ID=$(echo "$LINK" | sed -E 's/.*\/d\/([a-zA-Z0-9_-]+).*/\1/')

            if [ -z "$FILE_ID" ]; then
                error_msg "Invalid Link! Could not extract Google Drive ID."
            else
                prompt_input "Enter NEW folder name (No spaces, e.g. rainbow)" NEW_DIR
                NEW_DIR=$(echo "$NEW_DIR" | tr -d ' ')

                if [ -d "/var/www/html/$NEW_DIR" ]; then
                    error_msg "Folder '$NEW_DIR' already exists! Choose a different name."
                else
                    print_gap
                    step_msg "Downloading project from Google Drive..."
                    sudo mkdir -p /var/www/html/$NEW_DIR
                    sudo wget -qO /root/temp.zip "https://drive.google.com/uc?export=download&id=$FILE_ID"

                    step_msg "Extracting files to /var/www/html/$NEW_DIR ..."
                    sudo unzip -o /root/temp.zip -d /var/www/html/$NEW_DIR
                    sudo rm /root/temp.zip

                    if [ -f "/var/www/html/$NEW_DIR/database_backup.sql" ]; then
                        step_msg "Database found! Restoring automatically..."
                        sudo mysql < "/var/www/html/$NEW_DIR/database_backup.sql"
                        sudo rm "/var/www/html/$NEW_DIR/database_backup.sql"
                        info_msg "Database Restored Successfully!"
                    fi

                    step_msg "Setting permissions..."
                    sudo chown -R www-data:www-data /var/www/html/$NEW_DIR
                    sudo chmod -R 755 /var/www/html/$NEW_DIR

                    success_msg "Project Installed!  ➜  http://YOUR_IP/$NEW_DIR"
                fi
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        6)
            clear
            print_gap
            echo -e "${BOLD}${YELLOW}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${YELLOW}    ║          💾  BACKUP PROJECT TO GDRIVE                ║${RESET}"
            echo -e "${BOLD}${YELLOW}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "AVAILABLE PROJECTS" "$YELLOW"
            print_gap
            ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "    \033[93m  ▸  \033[0m\033[97m" $(NF-1) "\033[0m"}'
            print_gap

            prompt_input "Enter project folder name to backup" FOLDER_NAME

            if [ -d "/var/www/html/$FOLDER_NAME" ]; then
                DATE=$(date +"%d-%b-%Y_%I-%M-%p")
                BACKUP_NAME="${FOLDER_NAME}_Backup_$DATE.zip"

                print_gap
                step_msg "Exporting database to project folder..."
                sudo mysqldump --all-databases > /var/www/html/$FOLDER_NAME/database_backup.sql

                step_msg "Compressing project files..."
                cd /var/www/html/$FOLDER_NAME && sudo zip -r -q /root/$BACKUP_NAME .

                step_msg "Uploading to Google Drive..."
                rclone copy /root/$BACKUP_NAME gdrive:Server_Backups/

                sudo rm /var/www/html/$FOLDER_NAME/database_backup.sql /root/$BACKUP_NAME
                success_msg "Backup Complete! Check your Google Drive ➜ Server_Backups/"
            else
                error_msg "Project folder '$FOLDER_NAME' not found!"
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        7)
            clear
            print_gap
            echo -e "${BOLD}${RED}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${RED}    ║          🗑   DELETE A PROJECT                       ║${RESET}"
            echo -e "${BOLD}${RED}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "AVAILABLE PROJECTS" "$RED"
            print_gap
            ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "    \033[91m  ▸  \033[0m\033[97m" $(NF-1) "\033[0m"}'
            print_gap

            prompt_input "Enter project folder name to DELETE" DEL_DIR

            if [ -d "/var/www/html/$DEL_DIR" ]; then
                print_gap
                echo -e "    ${BOLD}${RED}    ⚠  WARNING: This action is PERMANENT and cannot be undone!${RESET}"
                echo -e "    ${RED}       You are about to delete:  ${BOLD}${WHITE}$DEL_DIR${RESET}"
                print_gap
                echo -ne "    ${BOLD}${RED}  ❯  Type ${WHITE}'YES'${RED} to confirm : ${RESET}"
                read -r CONFIRM

                if [ "$CONFIRM" == "YES" ]; then
                    sudo rm -rf /var/www/html/$DEL_DIR
                    success_msg "Project '$DEL_DIR' deleted successfully."
                else
                    warn_msg "Deletion cancelled. No changes were made."
                fi
            else
                error_msg "Folder '$DEL_DIR' not found!"
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        8)
            clear
            print_gap
            echo -e "${BOLD}${YELLOW}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${YELLOW}    ║          ⚙   INSTALL & SETUP RCLONE                 ║${RESET}"
            echo -e "${BOLD}${YELLOW}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            if ! command -v rclone &> /dev/null; then
                step_msg "Rclone not found. Installing now..."
                sudo -v ; curl https://rclone.org/install.sh | sudo bash
            else
                success_msg "Rclone is already installed!"
            fi

            print_gap
            info_msg "Opening Rclone Config..."
            warn_msg "Press 'n' for new remote, then name it 'gdrive'"
            print_gap
            rclone config
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        9)
            clear
            print_gap
            echo -e "${BOLD}${BLUE}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${BLUE}    ║          🛡   ADD SECURITY                           ║${RESET}"
            echo -e "${BOLD}${BLUE}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            step_msg "Updating server packages..."
            sudo apt-get update -y && sudo apt-get upgrade -y

            print_gap
            step_msg "Installing Fail2Ban (brute force protection)..."
            sudo apt-get install fail2ban -y
            sudo systemctl enable fail2ban
            sudo systemctl start fail2ban

            success_msg "Security hardening complete! Fail2Ban is active."
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        10)
            clear
            print_gap
            echo -e "${BOLD}${YELLOW}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${YELLOW}    ║          ⏰  SET AUTO NIGHTLY BACKUP                 ║${RESET}"
            echo -e "${BOLD}${YELLOW}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            step_msg "Creating nightly backup script at /root/nightly_master_backup.sh ..."

            cat << 'EOF' > /root/nightly_master_backup.sh
#!/bin/bash
DATE=$(date +"%d-%b-%Y")
sudo mysqldump --all-databases > /root/all_db_nightly.sql
for dir in /var/www/html/*/; do
    PROJ_NAME=$(basename "$dir")
    ZIP_NAME="${PROJ_NAME}_AutoBackup_${DATE}.zip"
    sudo cp /root/all_db_nightly.sql "$dir/database_backup.sql"
    cd "$dir" && sudo zip -r -q /root/$ZIP_NAME .
    sudo rm "$dir/database_backup.sql"
    rclone copy /root/$ZIP_NAME gdrive:Server_Backups/Auto_Nightly/
    rm /root/$ZIP_NAME
done
rm /root/all_db_nightly.sql
EOF

            sudo chmod +x /root/nightly_master_backup.sh

            step_msg "Registering cron job for 11:00 PM daily..."
            CRON_JOB="0 23 * * * /root/nightly_master_backup.sh > /root/backup_log.txt 2>&1"
            (crontab -l 2>/dev/null | grep -v "nightly_master_backup.sh"; echo "$CRON_JOB") | crontab -

            success_msg "Auto Nightly Backup set for 11:00 PM  ·  ALL projects will be backed up."
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        11)
            clear
            print_gap
            echo -e "${BOLD}${GREEN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${GREEN}    ║          🔒  AUTO SSL (HTTPS) SETUP                  ║${RESET}"
            echo -e "${BOLD}${GREEN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            prompt_input "Enter Domain Name (e.g. example.com)" SSL_DOMAIN
            prompt_input "Enter Email for SSL notices" SSL_EMAIL

            print_gap
            step_msg "Installing Certbot (if not already installed)..."
            sudo apt install certbot python3-certbot-apache -y >/dev/null 2>&1

            step_msg "Applying SSL Certificate... please wait."
            sudo certbot --apache -d $SSL_DOMAIN -d www.$SSL_DOMAIN --non-interactive --agree-tos -m $SSL_EMAIL --redirect

            if [ $? -eq 0 ]; then
                success_msg "SSL Installed! Your site is now secured with HTTPS 🔒"
            else
                error_msg "SSL Setup Failed! Make sure your domain DNS points to this server IP."
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        12)
            clear
            print_gap
            echo -e "${BOLD}${MAGENTA}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${MAGENTA}    ║          🔑  CHANGE WEB ADMIN PASSWORD               ║${RESET}"
            echo -e "${BOLD}${MAGENTA}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "DATABASE USERS" "$MAGENTA"
            print_gap
            sudo mysql -e "USE rainbow_school; SELECT id, name, mobile, role FROM users;"
            print_gap

            prompt_input "Enter User Mobile / Login ID" TARGET_ID
            prompt_input "Enter New Password" NEW_PASS

            step_msg "Hashing password securely with PHP..."
            HASHED_PASS=$(php -r "echo password_hash('$NEW_PASS', PASSWORD_DEFAULT);")

            sudo mysql -e "USE rainbow_school; UPDATE users SET password='$HASHED_PASS' WHERE mobile='$TARGET_ID';"

            if [ $? -eq 0 ]; then
                success_msg "Password updated & securely hashed for user: $TARGET_ID"
            else
                error_msg "Could not update password. Check user ID and try again."
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        13)
            clear
            print_gap
            echo -e "${BOLD}${CYAN}    ╔═══════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${CYAN}    ║          🔍  EXPLORE & EDIT FILES                    ║${RESET}"
            echo -e "${BOLD}${CYAN}    ╚═══════════════════════════════════════════════════════╝${RESET}"
            print_gap

            section_header "MYSQL DATABASES" "$MAGENTA"
            print_gap
            sudo mysql -e "SHOW DATABASES;"

            print_gap
            section_header "PROJECT FOLDERS" "$CYAN"
            print_gap
            ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "    \033[96m  ▸  \033[0m\033[97m" $(NF-1) "\033[0m"}'
            print_gap

            prompt_input "Enter folder name to explore (e.g. rainbow)" EXPLORE_DIR

            if [ -d "/var/www/html/$EXPLORE_DIR" ]; then
                cd "/var/www/html/$EXPLORE_DIR"
                print_gap
                success_msg "Entered folder successfully!"
                echo -e "    ${DIM}${WHITE}  📍 Path :  ${BOLD}$(pwd)${RESET}"

                section_header "PHP FILES FOUND" "$CYAN"
                print_gap

                mapfile -t php_files < <(find . -maxdepth 3 -type f -name "*.php" | sed 's|^\./||')

                if [ ${#php_files[@]} -eq 0 ]; then
                    error_msg "No PHP files found in this project."
                else
                    for i in "${!php_files[@]}"; do
                        printf "    ${MAGENTA}${BOLD}  %3d${RESET}  ${WHITE}%s${RESET}\n" "$((i+1))" "${php_files[$i]}"
                    done
                    print_gap
                    draw_line

                    echo -ne "    ${BOLD}${CYAN}  ❯  ${WHITE}Enter SL No. to Edit/View ${DIM}(0 to cancel)${RESET}${BOLD}${WHITE} : ${RESET}"
                    read -r FILE_NUM

                    if [[ "$FILE_NUM" =~ ^[0-9]+$ ]] && [ "$FILE_NUM" -gt 0 ] && [ "$FILE_NUM" -le "${#php_files[@]}" ]; then
                        FILE_INDEX=$((FILE_NUM-1))
                        TARGET_FILE="${php_files[$FILE_INDEX]}"
                        step_msg "Opening '$TARGET_FILE' in Nano Editor..."
                        sleep 1
                        sudo nano "$TARGET_FILE"
                        success_msg "Saved and closed '$TARGET_FILE'."
                    else
                        warn_msg "Action cancelled. No file was opened."
                    fi
                fi
            else
                error_msg "Folder '$EXPLORE_DIR' not found!"
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        0)
            clear
            print_gap
            print_gap
            echo -e "${BOLD}${CYAN}    ╔═════════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${CYAN}    ║                                                         ║${RESET}"
            echo -e "${BOLD}${CYAN}    ║${RESET}   ${GREEN}${BOLD}  ✔  Exiting Master Tool. Server is safe!           ${RESET}${BOLD}${CYAN}║${RESET}"
            echo -e "${BOLD}${CYAN}    ║${RESET}   ${DIM}${WHITE}     Have a great day, Prodip Bandhu!               ${RESET}${BOLD}${CYAN}║${RESET}"
            echo -e "${BOLD}${CYAN}    ║                                                         ║${RESET}"
            echo -e "${BOLD}${CYAN}    ╚═════════════════════════════════════════════════════════╝${RESET}"
            print_gap
            print_gap
            exit 0
            ;;

        # ══════════════════════════════════════════════════════════
        *)
            clear
            print_gap
            error_msg "Invalid option '$choice'! Please select between 0 and 13."
            sleep 1
            ;;
    esac
done
