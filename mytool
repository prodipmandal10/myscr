    prompt_input "Enter project folder name to backup" FOLDER_NAME
    if [ -d "/var/www/html/$FOLDER_NAME" ]; then
        DATE=$(date +"%d-%b-%Y_%I-%M-%p"); BACKUP_NAME="${FOLDER_NAME}_Backup_$DATE.zip"
        step_msg "Creating database dump..."; sudo mysqldump --all-databases > /var/www/html/$FOLDER_NAME/database_backup.sql
        step_msg "Zipping project..."; cd /var/www/html/$FOLDER_NAME && sudo zip -r -q $TEMP_DIR/$BACKUP_NAME .
        sudo chmod 777 $TEMP_DIR/$BACKUP_NAME
        step_msg "Uploading to Google Drive..."; rclone copy $TEMP_DIR/$BACKUP_NAME gdrive:Server_Backups/
        sudo rm /var/www/html/$FOLDER_NAME/database_backup.sql $TEMP_DIR/$BACKUP_NAME
        success_msg "Backup Complete! Check Google Drive → Server_Backups/"
    else error_msg "Folder not found!"; fi
    press_enter
}

# 12 ─ Install & Setup Rclone
do_12_rclone_setup() {
    page_header "⚙ " "INSTALL & SETUP RCLONE" "$BG_GREEN" "$BLACK"
    if ! command -v rclone &> /dev/null; then
        step_msg "Rclone not found. Installing..."
        sudo -v; curl https://rclone.org/install.sh | sudo bash
    else
        success_msg "Rclone is already installed!"
    fi
    rclone config
    press_enter
}

# 13 ─ Auto Nightly Backup
do_13_nightly_backup() {
    page_header "⏰" "SET AUTO NIGHTLY BACKUP" "$BG_GREEN" "$BLACK"
    cat << 'SCRIPT_EOF' > "$USER_HOME/nightly_master_backup.sh"
#!/bin/bash
DATE=$(date +"%d-%b-%Y")
sudo mysqldump --all-databases > /tmp/all_db_nightly.sql
for dir in /var/www/html/*/; do
    PROJ_NAME=$(basename "$dir"); ZIP_NAME="${PROJ_NAME}_AutoBackup_${DATE}.zip"
    sudo cp /tmp/all_db_nightly.sql "$dir/database_backup.sql"
    cd "$dir" && sudo zip -r -q /tmp/$ZIP_NAME .
    sudo rm "$dir/database_backup.sql"
    sudo chmod 777 /tmp/$ZIP_NAME
    rclone copy /tmp/$ZIP_NAME gdrive:Server_Backups/Auto_Nightly/
    sudo rm /tmp/$ZIP_NAME
done
sudo rm /tmp/all_db_nightly.sql
SCRIPT_EOF
    sudo chmod +x "$USER_HOME/nightly_master_backup.sh"
    CRON_JOB="0 23 * * * $USER_HOME/nightly_master_backup.sh > $USER_HOME/backup_log.txt 2>&1"
    (crontab -l 2>/dev/null | grep -v "nightly_master_backup.sh"; echo "$CRON_JOB") | crontab -
    success_msg "Auto Nightly Backup scheduled for 11:00 PM every day!"
    info_msg "Logs saved at: $USER_HOME/backup_log.txt"
    press_enter
}

# 14 ─ Server Health Check
do_14_health_check() {
    page_header "📊" "SERVER HEALTH CHECK" "$BG_BLUE"
    print_gap; echo -e "   ${BOLD}${WHITE}  SERVICE STATUS${RESET}"; print_gap
    if systemctl is-active --quiet apache2; then
        echo -e "   ${BG_GREEN}${BLACK}${BOLD}  ●  RUNNING  ${RESET}  ${WHITE}🌐  Web Server   ${GREEN}(Apache)${RESET}"
    else
        echo -e "   ${BG_RED}${WHITE}${BOLD}  ●  STOPPED  ${RESET}  ${WHITE}🌐  Web Server   ${RED}(Apache)${RESET}"
    fi
    print_gap
    if systemctl is-active --quiet mysql; then
        echo -e "   ${BG_GREEN}${BLACK}${BOLD}  ●  RUNNING  ${RESET}  ${WHITE}🗄  Database     ${GREEN}(MySQL)${RESET}"
    else
        echo -e "   ${BG_RED}${WHITE}${BOLD}  ●  STOPPED  ${RESET}  ${WHITE}🗄  Database     ${RED}(MySQL)${RESET}"
    fi
    print_gap
    UFW_STATUS=$(sudo ufw status | grep -w "Status")
    if [[ "$UFW_STATUS" == *"active"* ]]; then
        echo -e "   ${BG_GREEN}${BLACK}${BOLD}  ●  ACTIVE   ${RESET}  ${WHITE}🛡  Firewall     ${GREEN}(UFW)${RESET}"
    else
        echo -e "   ${BG_RED}${WHITE}${BOLD}  ●  INACTIVE ${RESET}  ${WHITE}🛡  Firewall     ${RED}(UFW)${RESET}"
    fi
    print_gap; draw_line; print_gap
    echo -e "   ${BOLD}${WHITE}  SYSTEM UPTIME${RESET}"; print_gap
    echo -e "   ${BG_BLUE}${WHITE}${BOLD}  ⏱  ${RESET}  ${YELLOW}${BOLD}$(uptime -p)${RESET}"
    print_gap; press_enter
}

