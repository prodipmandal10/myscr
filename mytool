#!/bin/bash

# Colors for design
GREEN="\e[32m"
RED="\e[31m"
BLUE="\e[34m"
YELLOW="\e[33m"
CYAN="\e[36m"
MAGENTA="\e[35m"
RESET="\e[0m"

while true; do
    clear
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${MAGENTA}                 👑 MADE BY PRODIP 👑                ${RESET}"
    echo -e "${YELLOW}=====================================================${RESET}"
    echo -e "${GREEN}      🌟 SERVER MANAGEMENT MASTER TOOL V3.7 🌟      ${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"
    echo -e "${CYAN}1) 🛠️  INITIAL SETUP (Install Apache, PHP, MySQL)${RESET}"
    echo -e "${CYAN}2) 🌐 SETUP DOMAIN (Link Domain to a Project)${RESET}"
    echo -e "${CYAN}3) 📊 SERVER HEALTH CHECK (Live Status)${RESET}"
    echo -e "${BLUE}-----------------------------------------------------${RESET}"
    echo -e "${CYAN}4) 📂 SHOW ALL PROJECTS (Running Websites)${RESET}"
    echo -e "${CYAN}5) 🚀 INSTALL NEW PROJECT (Full Zip Restore with DB)${RESET}"
    echo -e "${CYAN}6) 💾 BACKUP A SPECIFIC PROJECT (To GDrive)${RESET}"
    echo -e "${RED}7) 🗑️  DELETE A PROJECT (Remove Website)${RESET}"
    echo -e "${YELLOW}8) ⚙️  INSTALL & SETUP RCLONE (Auto)${RESET}"
    echo -e "${CYAN}9) 🛡️  ADD SECURITY (Auto Update & Firewall)${RESET}"
    echo -e "${YELLOW}10) ⏰ SET AUTO NIGHTLY BACKUP (11:00 PM)${RESET}"
    echo -e "${GREEN}11) 🔒 AUTO SSL (HTTPS) SETUP (Certbot)${RESET}"
    echo -e "${MAGENTA}12) 🔑 CHANGE WEB ADMIN PASSWORD (Live)${RESET}"
    echo -e "${YELLOW}13) 📝 FILE EXPLORER & EDITOR (Live Code Edit)${RESET}"
    echo -e "${CYAN}14) 🗄️  MYSQL DB MANAGER (Tree View, Create & Drop)${RESET}"
    echo -e "${MAGENTA}15) ☁️  AUTO DB RESTORE FROM GDRIVE (Fixes Root/User Error)${RESET}"
    echo -e "${GREEN}16) 🕵️‍♂️  DB CREDENTIAL FINDER (Smart Auto Search)${RESET}"
    echo -e "${RED}0) ❌ EXIT${RESET}"
    echo -e "${BLUE}=====================================================${RESET}"
    read -p "Select an option [0-16]: " choice

    case $choice in
        1)
            echo -e "\n${YELLOW}[*] INITIAL SERVER SETUP (Auto Install Packages)...${RESET}"
            sudo apt update -y && sudo apt upgrade -y
            sudo apt install apache2 mysql-server php libapache2-mod-php php-mysql zip unzip curl wget -y
            sudo mysql -e "CREATE USER IF NOT EXISTS 'admin'@'localhost' IDENTIFIED WITH mysql_native_password BY '12345'; GRANT ALL PRIVILEGES ON *.* TO 'admin'@'localhost' WITH GRANT OPTION; FLUSH PRIVILEGES;"
            sudo a2enmod rewrite
            sudo systemctl restart apache2
            echo -e "${GREEN}[+] Setup Complete! Your server is ready.${RESET}"
            read -p "Press Enter to return..."
            ;;
            
        2)
            echo -e "\n${YELLOW}[*] SETUP DOMAIN (Link Domain to Project)${RESET}"
            ls -d /var/www/html/*/ | awk -F/ '{print "- " $(NF-1)}' 2>/dev/null || echo "No projects found!"
            read -p "Enter the project folder name (e.g. rainbow): " PROJ_DIR
            if [ -d "/var/www/html/$PROJ_DIR" ]; then
                read -p "Enter your Domain Name (e.g. example.com): " DOMAIN_NAME
                CONF_FILE="/etc/apache2/sites-available/${DOMAIN_NAME}.conf"
                sudo bash -c "cat > $CONF_FILE" <<EOF
<VirtualHost *:80>
    ServerName $DOMAIN_NAME
    ServerAlias www.$DOMAIN_NAME
    DocumentRoot /var/www/html/$PROJ_DIR
    <Directory /var/www/html/$PROJ_DIR>
        AllowOverride All
        Require all granted
    </Directory>
</VirtualHost>
EOF
                sudo a2ensite ${DOMAIN_NAME}.conf && sudo systemctl restart apache2
                echo -e "${GREEN}[+] Domain ${DOMAIN_NAME} successfully linked!${RESET}"
            else
                echo -e "${RED}[-] Folder not found!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;
            
        3)
            echo -e "\n${YELLOW}[*] SERVER HEALTH CHECK (Live Status)${RESET}"
            systemctl is-active --quiet apache2 && echo -e "🌐 Web Server : ${GREEN}🟢 RUNNING${RESET}" || echo -e "🌐 Web Server : ${RED}🔴 STOPPED${RESET}"
            systemctl is-active --quiet mysql && echo -e "🗄️  Database  : ${GREEN}🟢 RUNNING${RESET}" || echo -e "🗄️  Database  : ${RED}🔴 STOPPED${RESET}"
            uptime -p
            read -p "Press Enter to return..."
            ;;

        4)
            echo -e "\n${YELLOW}[*] Scanning Server for Projects...${RESET}"
            ls -d /var/www/html/*/ | awk -F/ '{print "👉 " $(NF-1)}' 2>/dev/null || echo "No projects found."
            read -p "Press Enter to return..."
            ;;
        
        5)
            echo -e "\n${YELLOW}[*] INSTALL NEW PROJECT AUTO (With DB Magic Fix)${RESET}"
            read -p "Enter Google Drive Share Link (ZIP File): " LINK
            FILE_ID=$(echo "$LINK" | sed -E 's/.*\/d\/([a-zA-Z0-9_-]+).*/\1/')
            if [ -n "$FILE_ID" ]; then
                read -p "Enter NEW folder name: " NEW_DIR
                NEW_DIR=$(echo "$NEW_DIR" | tr -d ' ')
                sudo mkdir -p /var/www/html/$NEW_DIR
                echo -e "${GREEN}[*] Downloading and Extracting Project...${RESET}"
                sudo wget -qO /tmp/temp_proj.zip "https://drive.google.com/uc?export=download&id=$FILE_ID"
                sudo unzip -o /tmp/temp_proj.zip -d /var/www/html/$NEW_DIR
                sudo rm /tmp/temp_proj.zip
                
                # MAGIC FIX ADDED HERE FOR ZIP RESTORES
                if [ -f "/var/www/html/$NEW_DIR/database_backup.sql" ]; then
                    echo -e "${YELLOW}[*] Database found! Applying 'DEFINER' fix and Restoring...${RESET}"
                    sudo sed -i 's/DEFINER=[^*]*\*/\*/g' "/var/www/html/$NEW_DIR/database_backup.sql"
                    sudo sed -i 's/DEFINER=[^ ]* //g' "/var/www/html/$NEW_DIR/database_backup.sql"
                    sudo mysql < "/var/www/html/$NEW_DIR/database_backup.sql"
                    sudo rm "/var/www/html/$NEW_DIR/database_backup.sql"
                    echo -e "${GREEN}[+] Database Restored Successfully!${RESET}"
                fi

                sudo chown -R www-data:www-data /var/www/html/$NEW_DIR
                sudo chmod -R 755 /var/www/html/$NEW_DIR
                echo -e "${GREEN}[+] Project Installed! Link: http://YOUR_IP/$NEW_DIR ${RESET}"
            else
                echo -e "${RED}[-] Invalid Link!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;
            
        6)
            echo -e "\n${YELLOW}[*] BACKUP SPECIFIC PROJECT TO GDRIVE${RESET}"
            ls -d /var/www/html/*/ | awk -F/ '{print "- " $(NF-1)}' 2>/dev/null
            read -p "Enter project folder: " FOLDER_NAME
            if [ -d "/var/www/html/$FOLDER_NAME" ]; then
                DATE=$(date +"%d-%b-%Y_%I-%M-%p")
                BACKUP_NAME="${FOLDER_NAME}_Backup_$DATE.zip"
                echo -e "${GREEN}[*] Exporting DB and Zipping...${RESET}"
                sudo mysqldump --all-databases > /var/www/html/$FOLDER_NAME/database_backup.sql
                cd /var/www/html/$FOLDER_NAME && sudo zip -r -q /tmp/$BACKUP_NAME .
                echo -e "${GREEN}[*] Uploading to GDrive...${RESET}"
                rclone copy /tmp/$BACKUP_NAME gdrive:Server_Backups/
                sudo rm /var/www/html/$FOLDER_NAME/database_backup.sql /tmp/$BACKUP_NAME
                echo -e "${GREEN}[+] Backup Successful!${RESET}"
            else
                echo -e "${RED}[-] Folder not found!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;
            
        7)
            echo -e "\n${RED}[*] DELETE A PROJECT${RESET}"
            ls -d /var/www/html/*/ | awk -F/ '{print "- " $(NF-1)}' 2>/dev/null
            read -p "Enter folder to DELETE: " DEL_DIR
            if [ -d "/var/www/html/$DEL_DIR" ]; then
                read -p "Type 'YES' to confirm: " CONFIRM
                if [ "$CONFIRM" == "YES" ]; then
                    sudo rm -rf /var/www/html/$DEL_DIR
                    echo -e "${GREEN}[+] Project deleted!${RESET}"
                fi
            else
                echo -e "${RED}[-] Folder not found!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;
            
        8)
            echo -e "\n${YELLOW}[*] INSTALL & SETUP RCLONE${RESET}"
            command -v rclone &> /dev/null || (curl https://rclone.org/install.sh | sudo bash)
            rclone config
            read -p "Press Enter to return..."
            ;;
            
        9)
            echo -e "\n${YELLOW}[*] ADD SECURITY${RESET}"
            sudo apt-get update -y && sudo apt-get install fail2ban -y
            sudo systemctl enable fail2ban && sudo systemctl start fail2ban
            echo -e "${GREEN}[+] Protected!${RESET}"
            read -p "Press Enter to return..."
            ;;
            
        10)
            echo -e "\n${YELLOW}[*] AUTO SET NIGHTLY BACKUP (11:00 PM)${RESET}"
            cat << 'EOF' > /root/nightly_master_backup.sh
#!/bin/bash
DATE=$(date +"%d-%b-%Y")
sudo mysqldump --all-databases > /root/all_db_nightly.sql
for dir in /var/www/html/*/; do
    PROJ_NAME=$(basename "$dir")
    ZIP_NAME="${PROJ_NAME}_AutoBackup_${DATE}.zip"
    sudo cp /root/all_db_nightly.sql "$dir/database_backup.sql"
    cd "$dir" && sudo zip -r -q /tmp/$ZIP_NAME .
    sudo rm "$dir/database_backup.sql"
    rclone copy /tmp/$ZIP_NAME gdrive:Server_Backups/Auto_Nightly/
    rm /tmp/$ZIP_NAME
done
rm /root/all_db_nightly.sql
EOF
            sudo chmod +x /root/nightly_master_backup.sh
            CRON_JOB="0 23 * * * /root/nightly_master_backup.sh > /root/backup_log.txt 2>&1"
            (crontab -l 2>/dev/null | grep -v "nightly_master_backup.sh"; echo "$CRON_JOB") | crontab -
            echo -e "${GREEN}[+] Daily Auto Backup scheduled at 11:00 PM!${RESET}"
            read -p "Press Enter to return..."
            ;;
            
        11)
            echo -e "\n${YELLOW}[*] AUTO SSL SETUP${RESET}"
            read -p "Domain Name (e.g. example.com): " SSL_DOMAIN
            read -p "Email: " SSL_EMAIL
            sudo apt install certbot python3-certbot-apache -y >/dev/null 2>&1
            sudo certbot --apache -d $SSL_DOMAIN -d www.$SSL_DOMAIN --non-interactive --agree-tos -m $SSL_EMAIL --redirect
            read -p "Press Enter to return..."
            ;;

        12)
            echo -e "\n${MAGENTA}[*] CHANGE WEB ADMIN PASSWORD${RESET}"
            echo -e "Current DB Users:"
            sudo mysql -e "USE rainbow_school; SELECT id, name, mobile, role FROM users;" 2>/dev/null || echo "Table not found."
            read -p "Enter Target ID/Mobile: " TARGET_ID
            read -p "Enter New Password: " NEW_PASS
            sudo mysql -e "USE rainbow_school; UPDATE users SET password='$NEW_PASS' WHERE mobile='$TARGET_ID';"
            echo -e "${GREEN}[+] Updated!${RESET}"
            read -p "Press Enter to return..."
            ;;

        13)
            echo -e "\n${YELLOW}[*] 📝 FILE EXPLORER & EDITOR${RESET}"
            cd /var/www/html/ || continue
            shopt -s nullglob
            PROJ_ARRAY=(*/)
            shopt -u nullglob
            if [ ${#PROJ_ARRAY[@]} -eq 0 ]; then
                echo -e "${RED}[-] No projects found.${RESET}"
                read -p "Press Enter to return..."
                continue
            fi
            echo -e "${YELLOW}Available Projects:${RESET}"
            for i in "${!PROJ_ARRAY[@]}"; do
                PROJ_NAME=$(basename "${PROJ_ARRAY[$i]}")
                echo -e "${CYAN}$((i+1))) 📁 $PROJ_NAME${RESET}"
            done
            echo -e "${RED}0) 🔙 Go Back${RESET}"
            read -p "Select a project [0-${#PROJ_ARRAY[@]}]: " P_CHOICE
            if [[ "$P_CHOICE" == "0" ]]; then continue; fi
            if [[ "$P_CHOICE" =~ ^[0-9]+$ ]] && [[ "$P_CHOICE" -gt 0 && "$P_CHOICE" -le "${#PROJ_ARRAY[@]}" ]]; then
                SEL_PROJ=$(basename "${PROJ_ARRAY[$((P_CHOICE-1))]}")
                EXPLORE_DIR="/var/www/html/$SEL_PROJ"
                while true; do
                    clear
                    echo -e "${YELLOW}=====================================================${RESET}"
                    echo -e "${MAGENTA}   📂 EXPLORING: $EXPLORE_DIR ${RESET}"
                    echo -e "${YELLOW}=====================================================${RESET}"
                    cd "$EXPLORE_DIR" || break
                    shopt -s dotglob nullglob
                    ITEMS=(*)
                    shopt -u dotglob nullglob
                    for j in "${!ITEMS[@]}"; do
                        ITEM="${ITEMS[$j]}"
                        if [ -d "$ITEM" ]; then
                            echo -e "${BLUE}$((j+1))) 📁 $ITEM/ ${RESET}"
                        else
                            echo -e "${GREEN}$((j+1))) 📄 $ITEM ${RESET}"
                        fi
                    done
                    echo -e "${BLUE}-----------------------------------------------------${RESET}"
                    echo -e "${CYAN}N) ➕ Create New File Here${RESET}"
                    echo -e "${RED}0) 🔙 Go Back / Exit${RESET}"
                    read -p "Select [0-${#ITEMS[@]} or N to Create]: " F_CHOICE
                    if [[ "$F_CHOICE" == "0" ]]; then
                        if [[ "$EXPLORE_DIR" == "/var/www/html/$SEL_PROJ" ]]; then break; else EXPLORE_DIR=$(dirname "$EXPLORE_DIR"); fi
                    elif [[ "$F_CHOICE" == "N" || "$F_CHOICE" == "n" ]]; then
                        read -p "Enter new file name (e.g. index.php): " NEW_FILE
                        if [[ "$NEW_FILE" != *.* ]]; then NEW_FILE="$NEW_FILE.php"; fi
                        touch "$EXPLORE_DIR/$NEW_FILE" && nano "$EXPLORE_DIR/$NEW_FILE"
                    elif [[ "$F_CHOICE" =~ ^[0-9]+$ ]] && [[ "$F_CHOICE" -gt 0 && "$F_CHOICE" -le "${#ITEMS[@]}" ]]; then
                        SEL_ITEM="${ITEMS[$((F_CHOICE-1))]}"
                        if [ -d "$SEL_ITEM" ]; then EXPLORE_DIR="$EXPLORE_DIR/$SEL_ITEM"; elif [ -f "$SEL_ITEM" ]; then nano "$SEL_ITEM"; fi
                    fi
                done
            fi
            ;;

        14)
            echo -e "\n${YELLOW}[*] 🗄️ MYSQL DB MANAGER (Tree View)${RESET}"
            echo -e "${CYAN}Available Databases & Tables:${RESET}"
            DBS=$(sudo mysql -N -e "SHOW DATABASES" | grep -vE '^(information_schema|performance_schema|mysql|sys)$')
            if [ -z "$DBS" ]; then
                echo -e "${RED}No custom databases found.${RESET}"
            else
                for db in $DBS; do
                    echo -e "📂 ${GREEN}$db${RESET}"
                    TABLES=$(sudo mysql -N -e "SHOW TABLES IN \`$db\`;")
                    for tb in $TABLES; do echo -e "   ├── 📄 $tb"; done
                done
            fi
            echo -e "${BLUE}-----------------------------------------------------${RESET}"
            echo -e "${CYAN}1) ➕ Create New Database${RESET}"
            echo -e "${RED}2) 🗑️  Drop/Delete a Database${RESET}"
            echo -e "${RED}0) 🔙 Go Back${RESET}"
            read -p "Choice [0-2]: " DB_CH
            if [ "$DB_CH" == "1" ]; then
                read -p "Enter new database name: " NEW_DB
                sudo mysql -e "CREATE DATABASE IF NOT EXISTS \`$NEW_DB\`;"
                sudo mysql -e "GRANT ALL PRIVILEGES ON \`$NEW_DB\`.* TO 'admin'@'localhost'; FLUSH PRIVILEGES;"
                echo -e "${GREEN}[+] Database '$NEW_DB' created successfully!${RESET}"
            elif [ "$DB_CH" == "2" ]; then
                read -p "Enter database name to DELETE: " DEL_DB
                read -p "Type 'YES' to confirm: " CONFIRM
                if [ "$CONFIRM" == "YES" ]; then
                    sudo mysql -e "DROP DATABASE IF EXISTS \`$DEL_DB\`;"
                    echo -e "${GREEN}[+] Database '$DEL_DB' deleted!${RESET}"
                fi
            fi
            read -p "Press Enter to return..."
            ;;

        15)
            echo -e "\n${MAGENTA}[*] ☁️ AUTO DB RESTORE FROM GDRIVE (VPS/Local Fix)${RESET}"
            read -p "Enter GDrive Share Link of your SQL file: " LINK
            FILE_ID=$(echo "$LINK" | sed -E 's/.*\/d\/([a-zA-Z0-9_-]+).*/\1/')
            if [ -z "$FILE_ID" ]; then
                echo -e "${RED}[-] Invalid Link!${RESET}"
            else
                read -p "Enter Target Database Name (e.g. rainbow_school): " TARGET_DB
                echo -e "${GREEN}[*] Downloading SQL from GDrive...${RESET}"
                sudo wget -qO /tmp/downloaded_db.sql "https://drive.google.com/uc?export=download&id=$FILE_ID"
                
                echo -e "${YELLOW}[*] Applying SAFE MAGIC FIX: Removing 'DEFINER' errors...${RESET}"
                sudo sed -i '/^\/\*/s/DEFINER=[^*]*\*/\*/g' /tmp/downloaded_db.sql
                sudo sed -i '/^CREATE/s/DEFINER=[^ ]* //g' /tmp/downloaded_db.sql
                sudo sed -i '/^CREATE/s/DEFINER=\`[^\`]*\`@\`[^\`]*\` //g' /tmp/downloaded_db.sql
                
                echo -e "${GREEN}[*] Creating Database & Importing...${RESET}"
                sudo mysql -e "CREATE DATABASE IF NOT EXISTS \`$TARGET_DB\`;"
                sudo mysql -e "GRANT ALL PRIVILEGES ON \`$TARGET_DB\`.* TO 'admin'@'localhost'; FLUSH PRIVILEGES;"
                
                sudo mysql "$TARGET_DB" < /tmp/downloaded_db.sql
                
                if [ $? -eq 0 ]; then
                    echo -e "${GREEN}[+] Database Successfully Restored to '$TARGET_DB'!${RESET}"
                else
                    echo -e "${RED}[-] Error during import! Please check line number in error.${RESET}"
                fi
                sudo rm /tmp/downloaded_db.sql
            fi
            read -p "Press Enter to return..."
            ;;

        16)
            echo -e "\n${YELLOW}[*] 🕵️‍♂️ DB CREDENTIAL FINDER (Smart Auto Search)${RESET}"
            ls -d /var/www/html/*/ | awk -F/ '{print "- " $(NF-1)}' 2>/dev/null
            read -p "Enter project folder name to search (e.g. rainbow): " PROJ_DIR
            if [ -d "/var/www/html/$PROJ_DIR" ]; then
                echo -e "${GREEN}[*] Deep Scanning project: $PROJ_DIR ...${RESET}"

                FOUND_FILES=$(grep -rl --include=\*.php --include=\*.env -iE \
                  "(db_host|db_user|db_name|db_pass|db_password|mysqli_connect|DB_HOST|DB_USER|DB_NAME|DB_PASSWORD)" \
                  /var/www/html/$PROJ_DIR 2>/dev/null)

                if [ -z "$FOUND_FILES" ]; then
                    echo -e "${RED}[-] No DB config found in this project!${RESET}"
                else
                    SHOWN=0
                    for FILE in $FOUND_FILES; do

                        # Pattern 1: $var = 'value'
                        DB_HOST=$(grep -iE "(db_host|dbhost|\\\$host)\s*=\s*['\"]" "$FILE" | grep -oP "(?<=['\"])[^'\"]+(?=['\"])" | grep -v "^\s*$" | tail -1)
                        DB_USER=$(grep -iE "(db_user|dbuser|\\\$user|db_username)\s*=\s*['\"]" "$FILE" | grep -oP "(?<=['\"])[^'\"]+(?=['\"])" | grep -v "^\s*$" | tail -1)
                        DB_PASS=$(grep -iE "(db_pass|dbpass|\\\$pass|db_password|\\\$password)\s*=\s*['\"]" "$FILE" | grep -oP "(?<=['\"])[^'\"]+(?=['\"])" | grep -v "^\s*$" | tail -1)
                        DB_NAME=$(grep -iE "(db_name|dbname|\\\$dbname|\\\$database)\s*=\s*['\"]" "$FILE" | grep -oP "(?<=['\"])[^'\"]+(?=['\"])" | grep -v "^\s*$" | tail -1)

                        # Pattern 2: define('DB_HOST', 'value') — WordPress style
                        [ -z "$DB_HOST" ] && DB_HOST=$(grep -iP "define\s*\(\s*['\"]DB_HOST['\"]" "$FILE" | grep -oP "(?<=,\s*['\"])[^'\"]+(?=['\"])" | tail -1)
                        [ -z "$DB_USER" ] && DB_USER=$(grep -iP "define\s*\(\s*['\"]DB_USER['\"]" "$FILE" | grep -oP "(?<=,\s*['\"])[^'\"]+(?=['\"])" | tail -1)
                        [ -z "$DB_PASS" ] && DB_PASS=$(grep -iP "define\s*\(\s*['\"]DB_PASSWORD['\"]" "$FILE" | grep -oP "(?<=,\s*['\"])[^'\"]+(?=['\"])" | tail -1)
                        [ -z "$DB_NAME" ] && DB_NAME=$(grep -iP "define\s*\(\s*['\"]DB_NAME['\"]" "$FILE" | grep -oP "(?<=,\s*['\"])[^'\"]+(?=['\"])" | tail -1)

                        # Pattern 3: ENV style DB_HOST=value
                        [ -z "$DB_HOST" ] && DB_HOST=$(grep -iE "^DB_HOST\s*=" "$FILE" | cut -d'=' -f2 | tr -d "\"' " | tail -1)
                        [ -z "$DB_USER" ] && DB_USER=$(grep -iE "^DB_USER(NAME)?\s*=" "$FILE" | cut -d'=' -f2 | tr -d "\"' " | tail -1)
                        [ -z "$DB_PASS" ] && DB_PASS=$(grep -iE "^DB_PASS(WORD)?\s*=" "$FILE" | cut -d'=' -f2 | tr -d "\"' " | tail -1)
                        [ -z "$DB_NAME" ] && DB_NAME=$(grep -iE "^DB_NAME\s*=" "$FILE" | cut -d'=' -f2 | tr -d "\"' " | tail -1)

                        # শুধু সেই files দেখাবো যেখানে অন্তত একটা value আছে
                        if [ -n "$DB_HOST" ] || [ -n "$DB_USER" ] || [ -n "$DB_PASS" ] || [ -n "$DB_NAME" ]; then
                            SHOWN=$((SHOWN+1))
                            SHORT_FILE="${FILE#/var/www/html/$PROJ_DIR/}"
                            echo -e "\n${MAGENTA}📄 Config File : ${CYAN}$SHORT_FILE${RESET}"
                            echo -e "${BLUE}=====================================================${RESET}"
                            if [ -n "$DB_HOST" ]; then
                                echo -e "  🌐 Host      : ${GREEN}$DB_HOST${RESET}"
                            else
                                echo -e "  🌐 Host      : ${RED}Not Found${RESET}"
                            fi
                            if [ -n "$DB_NAME" ]; then
                                echo -e "  🗄️  Database  : ${GREEN}$DB_NAME${RESET}"
                            else
                                echo -e "  🗄️  Database  : ${RED}Not Found${RESET}"
                            fi
                            if [ -n "$DB_USER" ]; then
                                echo -e "  👤 Username  : ${GREEN}$DB_USER${RESET}"
                            else
                                echo -e "  👤 Username  : ${RED}Not Found${RESET}"
                            fi
                            if [ -n "$DB_PASS" ]; then
                                echo -e "  🔑 Password  : ${GREEN}$DB_PASS${RESET}"
                            else
                                echo -e "  🔑 Password  : ${RED}Not Found${RESET}"
                            fi
                            echo -e "${BLUE}=====================================================${RESET}"

                            # Live DB connection test
                            if [ -n "$DB_HOST" ] && [ -n "$DB_USER" ] && [ -n "$DB_NAME" ]; then
                                echo -e "  🔌 Testing DB Connection..."
                                if sudo mysql -h"$DB_HOST" -u"$DB_USER" -p"$DB_PASS" "$DB_NAME" -e ";" 2>/dev/null; then
                                    echo -e "  ✅ ${GREEN}Connection SUCCESS! DB is LIVE & Working.${RESET}"
                                else
                                    echo -e "  ❌ ${RED}Connection FAILED! Check credentials.${RESET}"
                                fi
                            fi
                            echo -e "${BLUE}=====================================================${RESET}"
                        fi
                    done

                    if [ "$SHOWN" -eq 0 ]; then
                        echo -e "${RED}[-] Files found but no parseable credentials extracted.${RESET}"
                    else
                        echo -e "\n${GREEN}[+] Total $SHOWN config file(s) found with credentials.${RESET}"
                    fi
                fi
            else
                echo -e "${RED}[-] Folder not found!${RESET}"
            fi
            read -p "Press Enter to return..."
            ;;

        0)
            clear
            echo -e "${GREEN}Exiting Master Tool. Server is safe. Have a great day, Prodip Bandhu!${RESET}"
            exit 0
            ;;
            
        *)
            echo -e "${RED}Invalid Option!${RESET}"; sleep 1 ;;
    esac
done
