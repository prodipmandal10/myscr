draw_line()  { echo -e "${DIM}${WHITE}   ─────────────────────────────────────────────────────────────${RESET}"; }
draw_dline() { echo -e "${BOLD}${CYAN}   ═════════════════════════════════════════════════════════════${RESET}"; }
print_gap()  { echo ""; }

# ── Section Title Bar ────────────────────────────────────────────────
sec_bar() {
    local LABEL="$1"
    local BG="$2"
    local FG="${3:-$WHITE}"
    print_gap
    echo -e "   ${BG}${BOLD}${FG}  ${LABEL}  ${RESET}"
    echo -e "   ${DIM}${WHITE}   · · · · · · · · · · · · · · · · · · · · · · · · · · · · · ·${RESET}"
}

# ── Menu Item ─────────────────────────────────────────────────────────
# menu_item <NUM> <NUM_BG> <ICON> <TITLE> <TITLE_COLOR> <DESC>
menu_item() {
    local NUM="$1"
    local NBG="$2"
    local ICON="$3"
    local TITLE="$4"
    local TC="$5"
    local DESC="$6"
    printf "   ${NBG}${BLACK}${BOLD} %2s ${RESET} " "$NUM"
    printf "${TC}${BOLD}%s  %-22s${RESET}" "$ICON" "$TITLE"
    printf "${DIM}${WHITE}%s${RESET}\n" "$DESC"
}

# ── Status Messages ───────────────────────────────────────────────────
success_msg() { print_gap; echo -e "   ${BG_GREEN}${BLACK}${BOLD}  ✔  SUCCESS  ${RESET}  ${LIME}${BOLD}$1${RESET}"; print_gap; }
error_msg()   { print_gap; echo -e "   ${BG_RED}${WHITE}${BOLD}  ✘  ERROR    ${RESET}  ${RED}${BOLD}$1${RESET}"; print_gap; }
info_msg()    { echo -e "   ${BG_BLUE}${WHITE}${BOLD}  ➜  INFO     ${RESET}  ${SKY}$1${RESET}"; }
warn_msg()    { print_gap; echo -e "   ${BG_YELLOW}${BLACK}${BOLD}  ⚠  WARNING  ${RESET}  ${YELLOW}${BOLD}$1${RESET}"; print_gap; }
step_msg()    { echo -e "   ${CYAN}  ◈  ${WHITE}$1${RESET}"; }

prompt_input() {
    print_gap
    echo -ne "   ${BG_CYAN}${BLACK}${BOLD}  ❯  ${RESET}  ${BOLD}${WHITE}$1 :${RESET}  "
    read -r "$2"
}

press_enter() {
    print_gap
    draw_dline
    echo -ne "   ${DIM}${WHITE}  Press ${BOLD}[ENTER]${RESET}${DIM}${WHITE} to return to menu...${RESET}"
    read
}

page_header() {
    local ICON="$1"; local TITLE="$2"; local BG="$3"; local FG="${4:-$WHITE}"
    clear; print_gap
    echo -e "   ${BG}${BOLD}${FG}  ${ICON}  ${TITLE}  ${RESET}"
    draw_line; print_gap
}

