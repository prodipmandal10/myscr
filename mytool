    prompt_input "Enter project folder name to DELETE" DEL_DIR
    if [ -d "/var/www/html/$DEL_DIR" ]; then
        print_gap
        echo -ne "   ${BG_RED}${WHITE}${BOLD}  ⚠  Type 'YES' to confirm :${RESET}  "
        read -r CONFIRM
        if [ "$CONFIRM" == "YES" ]; then
            sudo rm -rf /var/www/html/$DEL_DIR
            success_msg "Project '$DEL_DIR' deleted permanently."
        else warn_msg "Deletion cancelled."; fi
    else error_msg "Folder not found!"; fi
    press_enter
}

