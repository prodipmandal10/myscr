            # The find code has been updated to search deep everywhere (Level 5 depth)
            mapfile -t sql_files < <(sudo find /root /var/www/html /home /tmp -maxdepth 5 -type f -iname "*.sql" 2>/dev/null)

            if [ ${#sql_files[@]} -eq 0 ]; then
                error_msg "No .sql files found anywhere on the server!"
                warn_msg "Please upload the file to /root or /home using WinSCP first."
            else
                for i in "${!sql_files[@]}"; do
                    printf "    ${MAGENTA}${BOLD}  %3d${RESET}  ${WHITE}%s${RESET}\n" "$((i+1))" "${sql_files[$i]}"
                done
                print_gap
                draw_line

                echo -ne "    ${BOLD}${CYAN}  ❯  ${WHITE}Select SQL file to import ${DIM}(0 to cancel)${RESET}${BOLD}${WHITE} : ${RESET}"
                read -r FILE_NUM

                if [[ "$FILE_NUM" =~ ^[0-9]+$ ]] && [ "$FILE_NUM" -gt 0 ] && [ "$FILE_NUM" -le "${#sql_files[@]}" ]; then
                    FILE_INDEX=$((FILE_NUM-1))
                    TARGET_SQL="${sql_files[$FILE_INDEX]}"

                    print_gap
                    step_msg "Selected File: $TARGET_SQL"
                    
                    echo -ne "    ${BOLD}${CYAN}  ❯  ${WHITE}Enter MySQL 'root' Password : ${RESET}"
                    read -rs DB_PASS
                    echo ""
                    print_gap
                    
                    # Smart check: If file doesn't have CREATE DATABASE, we use the filename
                    HAS_CREATE=$(grep -i "CREATE DATABASE" "$TARGET_SQL")
                    
                    if [ -z "$HAS_CREATE" ]; then
                        # File is a standard dump, we must create the DB manually based on filename
                        DB_NAME=$(basename "$TARGET_SQL" .sql | sed 's/[^a-zA-Z0-9_]//g')
                        step_msg "Auto-creating missing database: '$DB_NAME' ..."
                        sudo mysql -u root -p"$DB_PASS" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\`;" 2>/dev/null
                        
                        step_msg "Importing data into '$DB_NAME'..."
                        sudo mysql -u root -p"$DB_PASS" "$DB_NAME" < "$TARGET_SQL"
                    else
                        # File has its own CREATE DATABASE instructions (like the one made by Option 14)
                        step_msg "Reading Master File... Automatically creating and importing all databases!"
                        sudo mysql -u root -p"$DB_PASS" < "$TARGET_SQL"
                    fi

                    if [ $? -eq 0 ]; then
                        success_msg "All Databases Imported Successfully!"
                    else
                        error_msg "Import Failed! Check password or SQL file format."
                    fi
                else
                    warn_msg "Action Cancelled."
                fi
            fi
            press_enter
            ;;

        # ══════════════════════════════════════════════════════════
        0)
            clear
            print_gap
            print_gap
            echo -e "${BOLD}${CYAN}    ╔═════════════════════════════════════════════════════════╗${RESET}"
            echo -e "${BOLD}${CYAN}    ║                                                         ║${RESET}"
            echo -e "${BOLD}${CYAN}    ║${RESET}   ${GREEN}${BOLD}  ✔  Exiting Master Tool. Server is safe!            ${RESET}${BOLD}${CYAN}║${RESET}"
            echo -e "${BOLD}${CYAN}    ║${RESET}   ${DIM}${WHITE}     Have a great day, Prodip Bandhu!               ${RESET}${BOLD}${CYAN}║${RESET}"
            echo -e "${BOLD}${CYAN}    ║                                                         ║${RESET}"
            echo -e "${BOLD}${CYAN}    ╚═════════════════════════════════════════════════════════╝${RESET}"
            print_gap
            print_gap
            exit 0
            ;;

        # ══════════════════════════════════════════════════════════
        *)
            clear
            print_gap
            error_msg "Invalid option '$choice'! Please select between 0 and 15."
            sleep 1
            ;;
    esac
done
