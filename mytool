draw_line() {
    echo -e "${DIM}${BLUE}    ─────────────────────────────────────────────────────────${RESET}"
}

draw_double_line() {
    echo -e "${BOLD}${CYAN}    ═════════════════════════════════════════════════════════${RESET}"
}

draw_thin_line() {
    echo -e "${DIM}${WHITE}    ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄${RESET}"
}

print_gap() {
    echo ""
}

section_header() {
    local TITLE="$1"
    local COLOR="${2:-$CYAN}"
    print_gap
    echo -e "    ${COLOR}${BOLD}┌─ ${TITLE} ${RESET}"
    draw_thin_line
}

menu_item() {
    local NUM="$1"
    local ICON="$2"
    local TEXT="$3"
    local COLOR="${4:-$CYAN}"
    printf "    ${COLOR}${BOLD}  %-2s${RESET}  ${WHITE}%s  ${COLOR}%s${RESET}\n" "$NUM" "$ICON" "$TEXT"
}

success_msg() {
    print_gap
    echo -e "    ${GREEN}${BOLD}  ✔  $1${RESET}"
    print_gap
}

error_msg() {
    print_gap
    echo -e "    ${RED}${BOLD}  ✘  $1${RESET}"
    print_gap
}

info_msg() {
    echo -e "    ${YELLOW}  ➜  $1${RESET}"
}

warn_msg() {
    print_gap
    echo -e "    ${YELLOW}${BOLD}  ⚠  $1${RESET}"
    print_gap
}

step_msg() {
    echo -e "    ${BLUE}  ◈  $1${RESET}"
}

prompt_input() {
    print_gap
    echo -ne "    ${CYAN}${BOLD}  ❯  ${WHITE}$1 : ${RESET}"
    read -r "$2"
}

press_enter() {
    print_gap
    draw_line
    echo -ne "    ${DIM}${WHITE}  Press ${BOLD}[ENTER]${RESET}${DIM}${WHITE} to return to menu...${RESET}"
    read
}

