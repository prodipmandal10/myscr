# 1 ─ Initial Setup
do_1_initial_setup() {
    page_header "🛠 " "INITIAL SERVER SETUP" "$BG_MAGENTA"
    step_msg "Updating system packages..."
    sudo apt update -y && sudo apt upgrade -y
    print_gap
    step_msg "Installing Apache, MySQL, PHP and essential tools..."
    sudo apt install apache2 mysql-server php libapache2-mod-php php-mysql zip unzip curl wget -y
    print_gap
    step_msg "Fixing MySQL permissions for admin user..."
    sudo mysql -e "CREATE USER IF NOT EXISTS 'admin'@'localhost' IDENTIFIED WITH mysql_native_password BY '12345'; GRANT ALL PRIVILEGES ON *.* TO 'admin'@'localhost' WITH GRANT OPTION; FLUSH PRIVILEGES;"
    step_msg "Enabling Apache rewrite module..."
    sudo a2enmod rewrite; sudo systemctl restart apache2
    success_msg "Setup Complete! Your server is ready."
    press_enter
}

# 2 ─ Setup Domain
do_2_setup_domain() {
    page_header "🌐" "SETUP DOMAIN" "$BG_MAGENTA"
    echo -e "   ${BOLD}${CYAN}  Available Projects:${RESET}"; print_gap
    ls -d /var/www/html/*/ 2>/dev/null | awk -F/ '{print "   \033[96m  ▸  \033[97m" $(NF-1) "\033[0m"}' || error_msg "No projects found!"
    print_gap
    prompt_input "Enter project folder name (e.g. rainbow)" PROJ_DIR
    if [ -d "/var/www/html/$PROJ_DIR" ]; then
        prompt_input "Enter your Domain Name (e.g. example.com)" DOMAIN_NAME
        CONF_FILE="/etc/apache2/sites-available/${DOMAIN_NAME}.conf"
        step_msg "Creating VirtualHost config for ${DOMAIN_NAME}..."
        sudo bash -c "cat > $CONF_FILE" <<EOF
<VirtualHost *:80>
    ServerName $DOMAIN_NAME
    ServerAlias www.$DOMAIN_NAME
    DocumentRoot /var/www/html/$PROJ_DIR
    <Directory /var/www/html/$PROJ_DIR>
        AllowOverride All
        Require all granted
    </Directory>
</VirtualHost>
EOF
        sudo a2ensite ${DOMAIN_NAME}.conf; sudo systemctl restart apache2
        success_msg "Domain ${DOMAIN_NAME} linked to '${PROJ_DIR}' successfully!"
        warn_msg "Make sure your DNS A Record points to this VPS IP."
    else
        error_msg "Folder '$PROJ_DIR' not found! Install the project first."
    fi
    press_enter
}

# 3 ─ Auto SSL
do_3_auto_ssl() {
    page_header "🔒" "AUTO SSL (HTTPS) SETUP" "$BG_MAGENTA"
    prompt_input "Enter Domain Name (e.g. example.com)" SSL_DOMAIN
    prompt_input "Enter Your Email (for SSL certificate)" SSL_EMAIL
    sudo apt install certbot python3-certbot-apache -y >/dev/null 2>&1
    sudo certbot --apache -d $SSL_DOMAIN -d www.$SSL_DOMAIN --non-interactive --agree-tos -m $SSL_EMAIL --redirect
    press_enter
}

# 4 ─ Smart Export All DBs
do_4_export_db() {
    page_header "📤" "SMART EXPORT & UPLOAD ALL DATABASES" "$BG_YELLOW" "$BLACK"
    step_msg "Finding all your databases..."
    print_gap
    echo -ne "   ${BG_CYAN}${BLACK}${BOLD}  ❯  ${RESET}  ${BOLD}${WHITE}Enter MySQL root Password :${RESET}  "
    read -rs DB_PASS; echo ""
    DB_LIST=$(sudo mysql -u root -p"$DB_PASS" -e "SHOW DATABASES;" 2>/dev/null \
        | awk '{print $1}' \
        | grep -v -E "^(Database|information_schema|performance_schema|mysql|sys)$")
    if [ -z "$DB_LIST" ]; then
        error_msg "No custom databases found to export!"
    else
        print_gap; info_msg "Databases found:"; print_gap
        echo "$DB_LIST" | while read -r db; do
            echo -e "   ${BG_GREEN}${BLACK}${BOLD}  ✔  ${RESET}  ${LIME}${BOLD}$db${RESET}"
        done
        print_gap
        FILE_NAME="Master_Database_Backup_$(date +%d-%b-%Y).sql"
        FILE_PATH="$USER_HOME/$FILE_NAME"
        step_msg "Exporting all databases..."
        sudo mysqldump -u root -p"$DB_PASS" --databases $DB_LIST > "$FILE_PATH"
        if [ $? -eq 0 ]; then
            sudo chmod 777 "$FILE_PATH"
            success_msg "Exported locally!"
            echo -e "   ${DIM}${WHITE}  Saved at:  ${BOLD}$FILE_PATH${RESET}"; print_gap
            if command -v rclone &> /dev/null && rclone config show gdrive &> /dev/null; then
                step_msg "Uploading to Google Drive → Server_Backups/Databases/ ..."
                rclone copy "$FILE_PATH" gdrive:Server_Backups/Databases/
                [ $? -eq 0 ] && success_msg "Backed up to Google Drive! ☁️" \
                             || error_msg "Upload failed! Check rclone connection."
            else
                warn_msg "Rclone not configured. Skipping Drive upload."
                info_msg "Use Option 12 to setup Rclone."
            fi
        else
            error_msg "Export failed! Check your MySQL password."
        fi
    fi
    press_enter
}

# 5 ─ Smart Import All DBs
do_5_import_db() {
    page_header "📥" "SMART 1-CLICK DATABASE IMPORT" "$BG_YELLOW" "$BLACK"
    TARGET_SQL=""
    print_gap
    echo -ne "   ${BG_CYAN}${BLACK}${BOLD}  ❯  ${RESET}  ${BOLD}${WHITE}Paste Google Drive Link ${DIM}(Leave blank for local file)${RESET}${BOLD}${WHITE} :${RESET}  "
    read -r G_LINK
    if [ -n "$G_LINK" ]; then
        FILE_ID=$(echo "$G_LINK" | sed -E 's/.*\/d\/([a-zA-Z0-9_-]+).*/\1/')
        if [ -z "$FILE_ID" ] || [ "$FILE_ID" == "$G_LINK" ]; then
            error_msg "Invalid Google Drive Link format!"
        else
            TARGET_SQL="/tmp/Smart_Imported_DB.sql"
            step_msg "Downloading from Google Drive..."
            sudo wget -qO "$TARGET_SQL" "https://drive.google.com/uc?export=download&id=$FILE_ID"
            if [ -s "$TARGET_SQL" ]; then success_msg "Downloaded successfully!"; else
                error_msg "Download failed! Check link sharing settings."; TARGET_SQL=""; fi
        fi
    else
        echo -e "   ${BOLD}${CYAN}  Scanning for local .sql files...${RESET}"; print_gap
        mapfile -t sql_files < <(sudo find $USER_HOME /root /tmp /var/www/html -maxdepth 5 -type f -iname "*.sql" 2>/dev/null)
        if [ ${#sql_files[@]} -eq 0 ]; then
            error_msg "No .sql files found on the server!"
        else
            for i in "${!sql_files[@]}"; do
                printf "   ${BG_MAGENTA}${WHITE}${BOLD}  %3d  ${RESET}  ${WHITE}%s${RESET}\n" "$((i+1))" "${sql_files[$i]}"
            done
            print_gap; draw_line; print_gap
            echo -ne "   ${BG_CYAN}${BLACK}${BOLD}  ❯  ${RESET}  ${BOLD}${WHITE}Select file number ${DIM}(0 to cancel)${RESET}${BOLD}${WHITE} :${RESET}  "
            read -r FILE_NUM
            if [[ "$FILE_NUM" =~ ^[0-9]+$ ]] && [ "$FILE_NUM" -gt 0 ] && [ "$FILE_NUM" -le "${#sql_files[@]}" ]; then
                TARGET_SQL="${sql_files[$((FILE_NUM-1))]}"
            fi
        fi
    fi
    if [ -n "$TARGET_SQL" ] && [ -f "$TARGET_SQL" ]; then
        print_gap; step_msg "Target: $TARGET_SQL"; print_gap
        echo -ne "   ${BG_CYAN}${BLACK}${BOLD}  ❯  ${RESET}  ${BOLD}${WHITE}Enter MySQL root Password :${RESET}  "
        read -rs DB_PASS; echo ""; print_gap
        HAS_CREATE=$(grep -i "CREATE DATABASE" "$TARGET_SQL")
        if [ -z "$HAS_CREATE" ]; then
            DB_NAME=$(basename "$TARGET_SQL" .sql | sed 's/[^a-zA-Z0-9_]//g')
            step_msg "Auto-creating database: '$DB_NAME' ..."
            sudo mysql -u root -p"$DB_PASS" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\`;" 2>/dev/null
            step_msg "Importing into '$DB_NAME'..."
            sudo mysql -u root -p"$DB_PASS" "$DB_NAME" < "$TARGET_SQL"
        else
            step_msg "Master backup detected. Importing all databases..."
            sudo mysql -u root -p"$DB_PASS" < "$TARGET_SQL"
        fi
        [ $? -eq 0 ] && success_msg "All databases imported successfully! 🎉" \
                     || error_msg "Import failed! Check password or SQL file."
        [ "$TARGET_SQL" == "/tmp/Smart_Imported_DB.sql" ] && sudo rm -f "$TARGET_SQL"
    else
        warn_msg "Action cancelled or file not found."
    fi
    press_enter
}

